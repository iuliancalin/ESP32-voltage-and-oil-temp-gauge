#include <SPI.h>
#include <Adafruit_GFX.h>    // Core graphics library
#include <Adafruit_ST7789.h> // Hardware-specific library for ST7789

// Include your custom gauge font
#include "DS_Digital_Bold16pt7b.h"   
#include "DS_Digital_Bold12pt7b.h" 
#include "Fonts/FreeSansBold9pt7b.h"

// --- HARDWARE PIN ASSIGNMENTS ---
#define TFT_CS         5   // Blue Wire
#define TFT_RST        4   // Yellow Wire
#define TFT_DC         2   // Orange Wire
#define TFT_MOSI      23   // Gray Wire (formerly Brown)
#define TFT_SCLK      18   // Green Wire
#define TFT_BL_PIN    15   // Backlight PWM Pin (Purple Wire) - LEAVE AS OUTPUT ONLY

#define VOLT_PIN      35   // Battery Voltage tracker
#define POT_PIN       32   // Instrument cluster dimmer circuit / Headlight sensor
#define OIL_TEMP_PIN  34   // NTC temperature sensor signal

// --- COLOR CONFIGURATIONS (BMW OEM Amber/Orange Theme) ---
#define COLOR_DARK_ORANGE  0x99E0 // Dark orange/amber background for the entire top half
#define COLOR_LIGHT_ORANGE 0xFCE0  // Bright light orange/amber for text
#define COLOR_LIGHT_GREEN  0x1D80

// --- SENSOR PARAMETERS ---
const float SERIES_RESISTOR = 10000.0; 
const float TEMP_CALIBRATION_OFFSET = 4.0; 

struct NTCPoint {
  float temp;
  float resistance;
};

const int TABLE_SIZE = 11;
NTCPoint table[TABLE_SIZE] = {
  {22, 56200}, {45, 21600}, {47, 20200}, {53, 16000}, {62, 11400},
  {71, 8500},  {75, 7200},  {83, 5500},  {87, 4700},  {90, 4500}, {92, 4200}
};

bool sensorDisconnected = false;
int lastPwmDuty = -1; // Cache for dimming PWM updates

// State variables for flicker-free rendering
float lastVoltage = -1.0;
float lastOilTemp = -1.0;
bool lastHeadlightsState = false;
bool firstRun = true;

// Initialize SPI & Adafruit Driver
SPIClass *vspi = new SPIClass(VSPI);
Adafruit_ST7789 tft = Adafruit_ST7789(vspi, TFT_CS, TFT_DC, TFT_RST);

// ==========================================
// SENSOR READING FUNCTIONS
// ==========================================
float readNtcResistance() {
  long sum = 0;
  for (int i = 0; i < 20; i++) {
    sum += analogRead(OIL_TEMP_PIN);
    delay(2);
  }
  float rawAdc = sum / 20.0;
  
  if (rawAdc <= 50 || rawAdc >= 4020) { 
    sensorDisconnected = true;
    return -1.0; 
  } 
  
  sensorDisconnected = false;
  return SERIES_RESISTOR * ((4095.0 - rawAdc) / rawAdc);
}

float calculateTemperature(float currentResistance) {
  if (sensorDisconnected || currentResistance <= 0) return 0;
  if (currentResistance >= table[0].resistance) return table[0].temp; 
  if (currentResistance <= table[TABLE_SIZE - 1].resistance) return table[TABLE_SIZE - 1].temp;

  for (int i = 0; i < TABLE_SIZE - 1; i++) {
    if (currentResistance <= table[i].resistance && currentResistance >= table[i + 1].resistance) {
      float r0 = table[i].resistance;
      float r1 = table[i + 1].resistance;
      float t0 = table[i].temp;
      float t1 = table[i + 1].temp;
      return t0 + (currentResistance - r0) * ((t1 - t0) / (r1 - r0));
    }
  }
  return 0; 
}

float readVoltage() {
  long sum = 0;
  for (int i = 0; i < 20; i++) {
    sum += analogRead(VOLT_PIN);
    delay(2);
  }
  float raw = sum / 20.0;
  float adcVoltage = (raw / 4095.0) * 3.3;
  
  return (4.115 * adcVoltage) + 3.128;
}

// ==========================================
// SETUP
// ==========================================
void setup() {
  Serial.begin(115200);
  analogReadResolution(12);

  // Initialize Backlight PWM Pin as safe, pure output
  pinMode(TFT_BL_PIN, OUTPUT);
  analogWrite(TFT_BL_PIN, 255); // Full brightness startup

  // Start the SPI bus with hardware pins
  vspi->begin(TFT_SCLK, -1, TFT_MOSI, TFT_CS);

  // Initialize display controller (172 x 320)
  tft.init(172, 320);
  tft.setRotation(3);        // Landscape flipped 180 (wires on right side)
  tft.invertDisplay(true);   // Corrects color inversion on ST7789
  tft.fillScreen(ST77XX_BLACK);

  // ==========================================
  // ANIMATED SPLASH SCREEN (Optimized to prevent flickering)
  // ==========================================
  tft.setTextColor(COLOR_LIGHT_ORANGE, ST77XX_BLACK); // Set solid background color to overwrite old dots
  tft.setFont(); 
  tft.setTextSize(4);
  tft.setCursor(80, 45); 
  tft.print("BMW E36");

  tft.setTextSize(2);
  tft.setCursor(80, 95);
  tft.print("Initializing");

  for (int i = 0; i < 12; i++) {
    // Overwrite old dots area with a tiny black box instead of clearing the whole screen
    tft.fillRect(238, 95, 45, 20, ST77XX_BLACK);
    tft.setCursor(238, 95);
    
    // Animated dots
    switch (i % 4) {
      case 1: tft.print(".");   break;
      case 2: tft.print("..");  break;
      case 3: tft.print("..."); break;
    }

    delay(180);
  }

  tft.fillScreen(ST77XX_BLACK);
}

// ==========================================
// MAIN LOOP (Flicker-Free, Multi-Update)
// ==========================================
void loop() {
  // ==========================================
  // PWM BACKLIGHT DIMMING & LIGHT STATE SENSING
  // ==========================================
  int potValue = analogRead(POT_PIN);
  int targetPwm = 255; // Full brightness during day
  bool headlightsOn = false;

  if (potValue >= 180) {
    headlightsOn = true;
    // Map cluster dimmer signal to PWM range (255 down to ~15 for night)
    targetPwm = map(potValue, 180, 4095, 10, 100); 
  }

  if (targetPwm != lastPwmDuty) {
    analogWrite(TFT_BL_PIN, targetPwm);
    lastPwmDuty = targetPwm;
  }

  // ==========================================
  // SENSOR READINGS
  // ==========================================
  float voltage = readVoltage();
  float ntcResistance = readNtcResistance();
  float oilTemp = calculateTemperature(ntcResistance);

  if (!sensorDisconnected && oilTemp > 0) {
    oilTemp += TEMP_CALIBRATION_OFFSET;
  }

  // ==========================================
  // ONE-TIME STATIC DRAW (Top block, lines & labels)
  // ==========================================
  if (firstRun) {
    tft.fillScreen(ST77XX_BLACK);
    
    // Draw the solid dark orange canvas across the entire top half (Y: 0 to 85)
    tft.fillRect(0, 0, 320, 85, COLOR_DARK_ORANGE);
    
    // Draw a 2-pixel light orange divider line splitting the left and right orange sections
    tft.fillRect(159, 0, 2, 85, COLOR_LIGHT_ORANGE);

    // Static Labels (printed directly on top of the dark orange background)
    tft.setFont(); // Standard font
    tft.setTextSize(2);
    tft.setTextColor(COLOR_LIGHT_ORANGE, COLOR_DARK_ORANGE); 
    
    tft.setCursor(25, 62);
    tft.print("Battery");
    tft.setCursor(185, 62);
    tft.print("Oil Temp");
    
    firstRun = false;
  }

  // ==========================================
  // DYNAMIC VOLTAGE UPDATE
  // ==========================================
  if (abs(voltage - lastVoltage) >= 0.1) {
    // Overwrite the old value with dark orange to keep the seamless header look
    tft.fillRect(5, 5, 150, 48, COLOR_DARK_ORANGE);

    tft.setFont(&DS_Digital_Bold16pt7b);
    tft.setTextColor(COLOR_LIGHT_ORANGE); 
    tft.setCursor(17, 48);   
    tft.print(voltage, 2);
    tft.setFont(&DS_Digital_Bold12pt7b);
    tft.print("V");
    
    lastVoltage = voltage;
  }

  // ==========================================
  // DYNAMIC TEMPERATURE UPDATE
  // ==========================================
  if (oilTemp != lastOilTemp) {
    // Overwrite the old value with dark orange to keep the seamless header look
    tft.fillRect(165, 5, 150, 48, COLOR_DARK_ORANGE);

    tft.setFont(&DS_Digital_Bold16pt7b);
    tft.setTextColor(COLOR_LIGHT_ORANGE); 
    tft.setCursor(185, 48); 
    
    if (sensorDisconnected || oilTemp == 0) {
      tft.print("---"); 
    } else {
      tft.print(oilTemp, 0); 
    }
    
    // Dynamic custom degree symbol drawing
    int16_t x1, y1;
    uint16_t w, h;
    String tempVal = (sensorDisconnected || oilTemp == 0) ? "---" : String((int)oilTemp);
    tft.getTextBounds(tempVal, 185, 34, &x1, &y1, &w, &h);
    int degreeX = x1 + w + 4; 
    
    tft.fillCircle(degreeX, 16, 2, COLOR_LIGHT_ORANGE);
    
    tft.setCursor(degreeX + 8, 42);
    tft.setFont(&DS_Digital_Bold12pt7b); 
    tft.print("C");
    
    lastOilTemp = oilTemp;
  }

// ==========================================
  // DYNAMIC HEADLIGHT ICON UPDATE (Font-based "D" + Vector Low Beams)
  // ==========================================
  if (headlightsOn != lastHeadlightsState) {
    int iconX = 40; 
    int iconY = 145; 
    
    // Determine the color based on headlight state (COLOR_LIGHT_GREEN to show)
    uint16_t activeColor = headlightsOn ? COLOR_LIGHT_GREEN : ST77XX_BLACK;

    // 1. Draw the Capital "D" using a clean sans-serif font
    tft.setFont(&FreeSansBold9pt7b); 
    tft.setTextColor(activeColor);
    tft.setCursor(iconX - 4, iconY + 12); // Position adjusted for standard font baseline
    tft.print("D");

    // 2. Draw the 3 downward-sloping beam lines
    // Top beam
    tft.drawLine(iconX - 10, iconY - 8, iconX - 22, iconY - 4, activeColor);
    tft.drawLine(iconX - 11, iconY - 7, iconX - 23, iconY - 3, activeColor); 
    tft.drawLine(iconX - 12, iconY - 6, iconX - 24, iconY - 2, activeColor);

    // Middle beam
    tft.drawLine(iconX - 10, iconY - 0, iconX - 23, iconY + 5, activeColor);
    tft.drawLine(iconX - 11, iconY + 1, iconX - 24, iconY + 6, activeColor); 
    tft.drawLine(iconX - 12, iconY + 2, iconX - 25, iconY + 7, activeColor);

    // Bottom beam
    tft.drawLine(iconX - 10, iconY + 9, iconX - 24, iconY + 14, activeColor);
    tft.drawLine(iconX - 11, iconY + 10, iconX - 25, iconY + 15, activeColor); 
    tft.drawLine(iconX - 12, iconY + 11, iconX - 26, iconY + 16, activeColor);

    lastHeadlightsState = headlightsOn;
  }

  delay(100); 
}
