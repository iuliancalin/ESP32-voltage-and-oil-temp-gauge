#include <SPI.h>
#include <Adafruit_GFX.h>    
#include <Adafruit_ST7789.h> 

// Custom Font Libraries
#include "custom_fonts/DS_Digital_Bold16pt7b.h"   
#include "custom_fonts/DS_Digital_Bold12pt7b.h" 
#include "custom_fonts/DS_Digital_Bold10pt7b.h" 
#include "Fonts/FreeSansBold9pt7b.h"
#include "custom_fonts/Nunito_Regular10pt7b.h"

// Modular Segment Architecture
#include "low_beam_icon.h"   
#include "Illumination.h"   
#include "sensor_parameter.h"
#include "splash_screen.h"
#include "hu_expiration.h"

// --- HARDWARE PIN ASSIGNMENTS ---
#define TFT_CS         5   
#define TFT_RST        4   
#define TFT_DC         2   
#define TFT_MOSI      23   
#define TFT_SCLK      18   
#define TFT_BL_PIN    15   

// --- COLOR CONFIGURATIONS ---
#define COLOR_DARK_ORANGE  0x4860 
#define COLOR_LIGHT_ORANGE 0xfd00  
#define COLOR_LIGHT_ORANGE_SMALL 0xfc80  

// =========================================================================
// --- CENTRALIZED LAYOUT CONFIGURATION ---
// =========================================================================
struct ElementLayout {
  int boxX, boxY, boxW, boxH;  // Bounding box for background clear blocks
  int textX, textY;            // Core coordinate data line positioning
  int labelX, labelY;          // Text identifier strings (e.g., "Battery")
};

// Layout coordinates for the Battery Voltage Monitor
const ElementLayout batteryUI = {
  .boxX   = 5,   .boxY   = 2,   // Background orange block position
  .boxW   = 150, .boxH   = 56,  // Background block width and height
  .textX  = 20,  .textY  = 55,  // The numeric voltage string position (e.g., "13.8V")
  .labelX = 25,  .labelY = 80   // The static "Battery" text label underneath
};

// Layout coordinates for the Oil Temperature display block
const ElementLayout oilTempUI = {
  .boxX   = 165, .boxY   = 2,   // Background orange block position
  .boxW   = 150, .boxH   = 56,  // Background block width and height
  .textX  = 185, .textY  = 55,  // The '---' or numeric temperature string position
  .labelX = 185, .labelY = 80   // The static "Oil Temp" text label underneath
};

// --- UI Vertical Divider Line Layout (Separates Battery and Oil Temp) ---
const int dividerX = 162;       // X-coordinate center placement on the display
const int dividerY = 0;         // Starting vertical coordinate (top edge)
const int dividerW = 3;         // Thickness of the divider line in pixels
const int dividerH = 70;        // Height of the divider line (matches background block)

// --- Headlight Indicator Placement ---
const int iconX = 0;           // Horizontal offset for the low beam symbol matrix
const int iconY = 70;          // Vertical coordinate where the 120x120 icon renders

// --- Custom Degree Circle (Symbol Erase Fix Context) ---
const int degreeBaseY = 16;     // Exact vertical center for the custom ° ring overlay
const int degreeOuterR = 6;     // Radius of the outer colored circle ring
const int degreeInnerR = 3;     // Radius of the inner black mask circle ring
// =========================================================================

// --- SENSOR & SYSTEM GLOBAL STATES ---
bool sensorDisconnected = false;// Flag tracking whether the NTC connection is lost
int lastPwmDuty = -1;           // Last written backlight brightness value (0-255)

// --- REFRESH MITIGATION STATES (Flicker-Free Guards) ---
float lastVoltage = -1.0;       // Stores the previous voltage reading to guard screen updates
float lastOilTemp = -1.0;       // Stores the previous temp calculation to guard screen updates
bool lastHeadlightsState = false;// Stores the last known headlight loop switch state
bool firstRun = true;           // Flag to force-render static assets on boot loop

// --- TIMED HU OVERLAY TRACKING ---
unsigned long bootTime = 0;     // Timestamp recorded right after setup() finishes execution
bool huVisible = true;          // Flag control for the temporary display warning element
const unsigned long HU_TIMEOUT = 10000; // Duration limit (10 seconds) before erasing HU popup
const int huX = 140;            // Horizontal position for the HU inspection warning popup
const int huY = 130;            // Vertical coordinate baseline for the HU alert box text

SPIClass *vspi = new SPIClass(VSPI);
Adafruit_ST7789 tft = Adafruit_ST7789(vspi, TFT_CS, TFT_DC, TFT_RST);

void setup() {
  Serial.begin(115200);
  analogReadResolution(12);

  pinMode(TFT_BL_PIN, OUTPUT);
  analogWrite(TFT_BL_PIN, 255); 

  vspi->begin(TFT_SCLK, -1, TFT_MOSI, TFT_CS);

  tft.init(172, 320);
  tft.setRotation(3);        
  tft.invertDisplay(true);   
  tft.fillScreen(ST77XX_BLACK);

  renderSplashScreen();
  bootTime = millis(); 
}

void loop() {
  bool headlightsOn = false;
  updateClusterIllumination(lastPwmDuty, headlightsOn);

  float voltage = readVoltage();
  float ntcResistance = readNtcResistance();
  float oilTemp = calculateTemperature(ntcResistance);

  if (!sensorDisconnected && oilTemp > 0) {
    oilTemp += TEMP_CALIBRATION_OFFSET;
  }

  // --- STATIC DRAW CANVAS ---
  if (firstRun) {
    tft.fillScreen(ST77XX_BLACK);
    tft.fillRect(0, 0, 320, 70, COLOR_DARK_ORANGE);
    tft.fillRect(dividerX, dividerY, dividerW, dividerH, COLOR_LIGHT_ORANGE);

    tft.setFont(); 
    tft.setTextSize(2);
    tft.setTextColor(COLOR_LIGHT_ORANGE_SMALL); 
    
    tft.setCursor(batteryUI.labelX, batteryUI.labelY);
    tft.print("Battery");
    tft.setCursor(oilTempUI.labelX, oilTempUI.labelY);
    tft.print("Oil Temp");
    
    firstRun = false;
  }

  // --- DYNAMIC VOLTAGE UPDATE ---
  if (abs(voltage - lastVoltage) >= 0.1) {
    tft.fillRect(batteryUI.boxX, batteryUI.boxY, batteryUI.boxW, batteryUI.boxH, COLOR_DARK_ORANGE);
    tft.setFont(&DS_Digital_Bold16pt7b);
    tft.setTextColor(COLOR_LIGHT_ORANGE); 
    tft.setCursor(batteryUI.textX, batteryUI.textY);   
    tft.print(voltage, 1); 
    tft.setFont(&FreeSansBold9pt7b);
    tft.print("V");
    lastVoltage = voltage;
  }

  // --- DYNAMIC TEMPERATURE UPDATE ---
  if (abs(oilTemp - lastOilTemp) >= 1.0) {
    // Erase the previous background block to remove ghosting
    tft.fillRect(oilTempUI.boxX, oilTempUI.boxY, oilTempUI.boxW, oilTempUI.boxH, COLOR_DARK_ORANGE);
    
    tft.setFont(&DS_Digital_Bold16pt7b);
    tft.setTextColor(COLOR_LIGHT_ORANGE); 
    tft.setCursor(oilTempUI.textX, oilTempUI.textY); 
    
    int degreeX = oilTempUI.textX; // Initialize variable
    
    if (sensorDisconnected || oilTemp == 0) {
      tft.print("---"); 
      // Push the degree symbol further right to clear the wide triple-dashes
      degreeX += 90; 
    } else {
      tft.print(oilTemp, 0); 
      // Dynamic shift: 2 digits = 42px offset, 3 digits (100°C+) = 60px offset
      degreeX += (oilTemp >= 100) ? 60 : 42; 
    }
    
    // --- DEGREE SYMBOL DRAWING ---
    tft.fillCircle(degreeX, degreeBaseY, degreeOuterR, COLOR_LIGHT_ORANGE);
    tft.fillCircle(degreeX, degreeBaseY, degreeInnerR, COLOR_DARK_ORANGE); 
    
    tft.setCursor(degreeX + 9, oilTempUI.textY);
    tft.setFont(&FreeSansBold9pt7b); 
    tft.print("C");
    
    // Update state to lock in refresh guard
    lastOilTemp = oilTemp;
  }

  // --- DYNAMIC HEADLIGHT ICON UPDATE ---
  if (headlightsOn != lastHeadlightsState) {
    drawLowBeamIcon(iconX, iconY, headlightsOn);
    lastHeadlightsState = headlightsOn;
  }

  // --- TIMED HU EXPIRATION OVERLAY ---
  handleHuExpiration(huVisible, bootTime, HU_TIMEOUT);

  delay(100); 
}
